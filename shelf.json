{
  "pillcrowShelf": 1,
  "name": "Example.com Search Source",
  "home": "example.com",
  "about": "A search-only Pillcrow source template for a title-search HTTPS JSON API.",
  "books": [],
  "search": {
    "version": 1,
    "format": "json",
    "url": "https://example.com/api/books?search={query}&page={page}",
    "items": "/results",
    "fields": {
      "id": "/id",
      "title": "/title",
      "author": "/author",
      "file": "/file",
      "words": "/words"
    }
  }
}
